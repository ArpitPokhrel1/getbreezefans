<section class="bp-proof">
  <div class="bp-section-heading">
    <span class="bp-eyebrow">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
  </div>

  <div class="bp-proof-grid">
    {% for block in section.blocks %}
      <article {{ block.shopify_attributes }}>
        <strong>{{ block.settings.title }}</strong>
        <p>{{ block.settings.copy }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "BreezePod proof",
  "tag": "section",
  "class": "bp-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Why it feels credible"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Honest product pages convert better than oversized promises."
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Real specifications"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Color, sizing, use cases, care expectations, and supplier verification notes are written plainly."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BreezePod proof",
      "blocks": [
        {
          "type": "proof",
          "settings": {
            "title": "Real specifications",
            "copy": "Color, sizing, use cases, care expectations, and supplier verification notes are written plainly."
          }
        },
        {
          "type": "proof",
          "settings": {
            "title": "Clear limits",
            "copy": "The fan is personal airflow and the blanket is a passive textile layer, not medical cooling equipment."
          }
        },
        {
          "type": "proof",
          "settings": {
            "title": "Checkout trust",
            "copy": "Shopify checkout, U.S. delivery focus, tracked orders, and the 10-day inspection window sit close to purchase."
          }
        }
      ]
    }
  ]
}
{% endschema %}
