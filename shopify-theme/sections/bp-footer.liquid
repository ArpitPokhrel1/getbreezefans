<footer class="bp-footer">
  <strong>{{ section.settings.brand_name | default: shop.name }}</strong>
  <span>{{ section.settings.footer_text }}</span>
</footer>

{% schema %}
{
  "name": "BreezePod footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "BreezePod"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text",
      "default": "Professional summer comfort products for customers in the United States."
    }
  ]
}
{% endschema %}
